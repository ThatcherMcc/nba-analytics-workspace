# .env.local in nba-data-backend
UPDATE_API_KEY= # api key to the nba-prop-website. Used to update the database while website is running.
POSTGRES_URL= # url to the postgres database directly. Used to store the data.
ODDS_API_KEY= # sports-game-odds free key. Call for specifc prop odds. USE SPARINGLY.
SCRAPE_PROXIES="proxy,proxy2,..." # proxies to use for scraping.

# .env in nba-prop-website
UPDATE_API_KEY= # api key to the nba-prop-website. Used to update the database while website is running.
POSTGRES_URL= # url to the postgres database directly. Used to store the data.
REVALIDATE_SECRET= # secret for POST /api/revalidate; call after a scrape (e.g. GitHub Actions) to clear cached homepage and player pages.